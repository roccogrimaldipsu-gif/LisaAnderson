<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lisa Anderson, MSN, PMHNP-BC | Psychiatric Telehealth</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --sage: #7d9b8a;
    --sage-light: #a8c0b0;
    --sage-pale: #e8f0eb;
    --cream: #f9f6f0;
    --warm-white: #fdfcf8;
    --charcoal: #2c2c2c;
    --mid: #5a5a5a;
    --light-text: #8a8a8a;
    --gold: #b8965a;
    --gold-light: #d4b07a;
    --border: #e0dbd2;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--warm-white);
    color: var(--charcoal);
    font-size: 16px;
    line-height: 1.6;
    overflow-x: hidden;
  }

  /* NAV */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.2rem 3rem;
    background: rgba(253, 252, 248, 0.92);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
    transition: all 0.3s;
  }

  .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--charcoal);
    letter-spacing: 0.02em;
  }

  .nav-logo span {
    color: var(--sage);
    font-style: italic;
  }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
  }

  .nav-links a {
    text-decoration: none;
    color: var(--mid);
    font-size: 0.82rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--sage); }

  .nav-cta {
    background: var(--sage);
    color: white !important;
    padding: 0.55rem 1.4rem;
    border-radius: 2px;
    font-weight: 500 !important;
  }

  .nav-cta:hover { background: var(--sage-light); color: white !important; }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    padding-top: 5rem;
    overflow: hidden;
  }

  .hero-left {
    padding: 5rem 4rem 5rem 6rem;
    position: relative;
  }

  .hero-left::before {
    content: '';
    position: absolute;
    top: -20%;
    left: -10%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(125,155,138,0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-eyebrow {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sage);
    margin-bottom: 1.2rem;
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .hero-eyebrow::before {
    content: '';
    display: inline-block;
    width: 2rem;
    height: 1px;
    background: var(--sage);
  }

  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.8rem, 4.5vw, 4.2rem);
    font-weight: 300;
    line-height: 1.15;
    color: var(--charcoal);
    margin-bottom: 0.5rem;
  }

  .hero-title em {
    font-style: italic;
    color: var(--sage);
  }

  .hero-subtitle {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--gold);
    letter-spacing: 0.05em;
    margin-bottom: 1.8rem;
  }

  .hero-desc {
    font-size: 0.95rem;
    color: var(--mid);
    line-height: 1.8;
    max-width: 42ch;
    margin-bottom: 2.5rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-block;
    background: var(--sage);
    color: white;
    padding: 0.85rem 2rem;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    border-radius: 2px;
    transition: all 0.25s;
  }

  .btn-primary:hover {
    background: #6a8877;
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(125,155,138,0.3);
  }

  .btn-outline {
    display: inline-block;
    border: 1px solid var(--border);
    color: var(--mid);
    padding: 0.85rem 2rem;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.06em;
    border-radius: 2px;
    transition: all 0.25s;
  }

  .btn-outline:hover {
    border-color: var(--sage);
    color: var(--sage);
  }

  .hero-right {
    position: relative;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--sage-pale);
    overflow: hidden;
  }

  .hero-right::before {
    content: '';
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(ellipse at 30% 70%, rgba(125,155,138,0.2) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 20%, rgba(184,150,90,0.1) 0%, transparent 50%);
  }

  .hero-photo-frame {
    position: relative;
    width: 360px;
    height: 440px;
    z-index: 2;
    border-radius: 4px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.15);
  }

  .hero-photo-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--sage-light) 0%, var(--sage) 100%);
    border-radius: 3px;
    transform: rotate(3deg);
    opacity: 0.4;
  }

  .hero-photo-placeholder {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    background: linear-gradient(160deg, #c5d8cc 0%, #8fb09a 100%);
    border-radius: 3px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-photo-placeholder::before {
    content: '';
    position: absolute;
    bottom: -20px;
    left: 50%;
    transform: translateX(-50%);
    width: 180px;
    height: 220px;
    background: rgba(255,255,255,0.15);
    border-radius: 50% 50% 0 0;
  }

  .photo-initials {
    font-family: 'Cormorant Garamond', serif;
    font-size: 4rem;
    font-weight: 300;
    color: white;
    position: relative;
    z-index: 1;
    letter-spacing: 0.1em;
  }

  .photo-note {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.75);
    position: relative;
    z-index: 1;
    margin-top: 0.5rem;
  }

  .hero-badge {
    position: absolute;
    bottom: -1.5rem;
    right: -1.5rem;
    background: white;
    border-radius: 3px;
    padding: 1rem 1.2rem;
    box-shadow: 0 8px 32px rgba(0,0,0,0.1);
    z-index: 3;
    min-width: 160px;
  }

  .badge-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    font-weight: 500;
    color: var(--sage);
    line-height: 1;
  }

  .badge-label {
    font-size: 0.72rem;
    color: var(--light-text);
    letter-spacing: 0.05em;
    margin-top: 0.2rem;
  }

  /* MARQUEE */
  .marquee-bar {
    background: var(--charcoal);
    color: var(--sage-light);
    padding: 0.9rem 0;
    overflow: hidden;
    white-space: nowrap;
  }

  .marquee-inner {
    display: inline-block;
    animation: marquee 25s linear infinite;
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .marquee-inner span { margin: 0 3rem; color: var(--gold); }

  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* SECTIONS */
  section { padding: 6rem 6rem; }

  .section-label {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sage);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .section-label::before {
    content: '';
    display: inline-block;
    width: 1.5rem;
    height: 1px;
    background: var(--sage);
  }

  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 3vw, 2.8rem);
    font-weight: 300;
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }

  /* ABOUT */
  .about {
    background: var(--cream);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .about-text p {
    font-size: 0.95rem;
    color: var(--mid);
    line-height: 1.9;
    margin-bottom: 1.2rem;
  }

  .credentials-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 2rem;
  }

  .credential-card {
    background: white;
    border: 1px solid var(--border);
    padding: 1.2rem;
    border-radius: 3px;
    border-top: 2px solid var(--sage);
  }

  .cred-title {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--light-text);
    margin-bottom: 0.3rem;
  }

  .cred-body {
    font-size: 0.85rem;
    color: var(--charcoal);
    font-weight: 400;
  }

  /* SERVICES */
  .services {
    background: var(--warm-white);
  }

  .services-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    margin-bottom: 4rem;
    align-items: end;
  }

  .services-intro {
    font-size: 0.95rem;
    color: var(--mid);
    line-height: 1.8;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .service-card {
    background: white;
    border: 1px solid var(--border);
    padding: 2rem;
    border-radius: 3px;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }

  .service-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: var(--sage);
    transform: scaleX(0);
    transition: transform 0.3s;
    transform-origin: left;
  }

  .service-card:hover {
    box-shadow: 0 8px 30px rgba(0,0,0,0.07);
    transform: translateY(-2px);
  }

  .service-card:hover::after { transform: scaleX(1); }

  .service-icon {
    width: 40px;
    height: 40px;
    margin-bottom: 1.2rem;
    color: var(--sage);
  }

  .service-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--charcoal);
    margin-bottom: 0.6rem;
  }

  .service-desc {
    font-size: 0.85rem;
    color: var(--mid);
    line-height: 1.7;
  }

  /* TELEHEALTH PROCESS */
  .process {
    background: var(--charcoal);
    color: white;
  }

  .process .section-label { color: var(--sage-light); }
  .process .section-label::before { background: var(--sage-light); }
  .process .section-title { color: white; }

  .steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    margin-top: 3rem;
    position: relative;
  }

  .steps::before {
    content: '';
    position: absolute;
    top: 1.8rem;
    left: 10%;
    right: 10%;
    height: 1px;
    background: rgba(255,255,255,0.1);
  }

  .step {
    text-align: center;
    position: relative;
  }

  .step-num {
    width: 3.5rem;
    height: 3.5rem;
    background: rgba(125,155,138,0.2);
    border: 1px solid rgba(125,155,138,0.4);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem;
    color: var(--sage-light);
    position: relative;
    z-index: 1;
  }

  .step-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem;
    font-weight: 500;
    color: white;
    margin-bottom: 0.6rem;
  }

  .step-desc {
    font-size: 0.83rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.7;
  }

  /* CONDITIONS */
  .conditions {
    background: var(--sage-pale);
  }

  .conditions-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2.5rem;
  }

  .condition-tag {
    background: white;
    border: 1px solid var(--sage-light);
    color: var(--charcoal);
    padding: 0.5rem 1.2rem;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 400;
    transition: all 0.2s;
  }

  .condition-tag:hover {
    background: var(--sage);
    border-color: var(--sage);
    color: white;
  }

  /* PROFILES */
  .profiles {
    background: var(--warm-white);
  }

  .profiles-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    margin-top: 3rem;
  }

  .profile-card {
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 2rem;
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    background: white;
    transition: all 0.3s;
    text-decoration: none;
    color: inherit;
  }

  .profile-card:hover {
    box-shadow: 0 8px 30px rgba(0,0,0,0.08);
    transform: translateY(-2px);
    border-color: var(--sage-light);
  }

  .profile-icon {
    width: 48px;
    height: 48px;
    background: var(--sage-pale);
    border-radius: 3px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .profile-icon svg { color: var(--sage); }

  .profile-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--charcoal);
    margin-bottom: 0.3rem;
  }

  .profile-source {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sage);
    margin-bottom: 0.5rem;
  }

  .profile-desc {
    font-size: 0.83rem;
    color: var(--mid);
    line-height: 1.6;
  }

  .profile-arrow {
    margin-left: auto;
    color: var(--light-text);
    flex-shrink: 0;
    margin-top: 0.2rem;
    transition: transform 0.2s;
  }

  .profile-card:hover .profile-arrow {
    transform: translateX(3px);
    color: var(--sage);
  }

  /* CONTACT */
  .contact {
    background: var(--cream);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: start;
  }

  .contact-info p {
    font-size: 0.95rem;
    color: var(--mid);
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.9rem;
    color: var(--charcoal);
  }

  .contact-item svg {
    color: var(--sage);
    flex-shrink: 0;
  }

  .contact-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 2.5rem;
  }

  .contact-card-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.6rem;
    font-weight: 400;
    margin-bottom: 0.5rem;
  }

  .contact-card-sub {
    font-size: 0.85rem;
    color: var(--mid);
    margin-bottom: 2rem;
  }

  .quick-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .quick-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.2rem;
    border: 1px solid var(--border);
    border-radius: 2px;
    text-decoration: none;
    color: var(--charcoal);
    font-size: 0.88rem;
    font-weight: 400;
    transition: all 0.2s;
  }

  .quick-link:hover {
    border-color: var(--sage);
    background: var(--sage-pale);
    color: var(--sage);
  }

  /* FOOTER */
  footer {
    background: var(--charcoal);
    color: rgba(255,255,255,0.55);
    padding: 3rem 6rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-brand {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1rem;
    color: white;
  }

  .footer-brand span { color: var(--sage-light); font-style: italic; }

  .footer-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }

  .footer-links a {
    text-decoration: none;
    color: rgba(255,255,255,0.45);
    font-size: 0.8rem;
    transition: color 0.2s;
  }

  .footer-links a:hover { color: var(--sage-light); }

  .footer-copy {
    font-size: 0.78rem;
    width: 100%;
    text-align: center;
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-top: 1.5rem;
    margin-top: 0.5rem;
  }

  /* ANIMATIONS */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .fade-up {
    opacity: 0;
    animation: fadeUp 0.7s ease forwards;
  }

  .fade-up:nth-child(1) { animation-delay: 0.1s; }
  .fade-up:nth-child(2) { animation-delay: 0.25s; }
  .fade-up:nth-child(3) { animation-delay: 0.4s; }
  .fade-up:nth-child(4) { animation-delay: 0.55s; }

  /* MOBILE */
  @media (max-width: 900px) {
    nav { padding: 1rem 1.5rem; }
    .nav-links { display: none; }
    .hero { grid-template-columns: 1fr; }
    .hero-left { padding: 7rem 2rem 3rem; }
    .hero-right { height: 400px; }
    section { padding: 4rem 2rem; }
    .about, .contact { grid-template-columns: 1fr; gap: 3rem; }
    .services-header { grid-template-columns: 1fr; gap: 1rem; }
    .services-grid { grid-template-columns: 1fr; }
    .steps { grid-template-columns: 1fr 1fr; }
    .steps::before { display: none; }
    .profiles-grid { grid-template-columns: 1fr; }
    footer { padding: 2rem; flex-direction: column; align-items: flex-start; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-logo">Lisa Anderson <span>PMHNP-BC</span></div>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#services">Services</a></li>
    <li><a href="#conditions">Conditions</a></li>
    <li><a href="#profiles">Reviews</a></li>
    <li><a href="#contact" class="nav-cta">Book Appointment</a></li>
  </ul>
</nav>

<!-- HERO -->
<section class="hero" id="home">
  <div class="hero-left">
    <div class="hero-eyebrow fade-up">Psychiatric Telehealth · Massachusetts</div>
    <h1 class="hero-title fade-up">
      Compassionate<br>
      <em>Mental Health</em><br>
