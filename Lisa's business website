    </p>
    <div class="hero-actions fade-up">
      <a href="https://www.tebra.com/care/provider/lisa-anderson-pmhnp-1558822296" target="_blank" class="btn-primary">Schedule an Appointment</a>
      <a href="#about" class="btn-outline">Learn More</a>
    </div>
  </div>
  <div class="hero-right">
    <div class="hero-photo-frame">
      <div class="hero-photo-bg"></div>
      <img src="data:image/jpeg;base64," alt="Lisa Anderson, PMHNP-BC" style="width:100%;height:100%;object-fit:cover;object-position:center top;border-radius:3px;position:relative;z-index:1;" />
      </div>
      <div class="hero-badge">
        <div class="badge-number">30+</div>
        <div class="badge-label">Years of Nursing<br>Experience</div>
      </div>
    </div>
  </div>
</section>

<!-- MARQUEE -->
